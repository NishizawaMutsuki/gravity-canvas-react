{
  "name": "gravity-canvas-react",
  "version": "1.0.0",
  "description": "Gravity-based particle simulation with connecting lines — a React canvas component",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "canvas",
    "particles",
    "gravity",
    "animation",
    "background",
    "interactive"
  ],
  "author": "Mutsuki Nishizawa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mutsuki15/gravity-canvas-react"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
